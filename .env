# =============== EXCHANGE ===============
EXCHANGE_NAME=binance
QUOTE_ASSET=USDT


# =============== SCAN SETTINGS ===============
SCAN_BATCH_SIZE=20
LOOP_SLEEP_SECONDS=5
MAX_EMITS_PER_LOOP=1   # প্রতি loop এ শুধু 1টা best signal


# =============== SCORE THRESHOLDS ===============
MIN_SIGNAL_SCORE=85
THRESH_QUICK=92
THRESH_MID=85
THRESH_TREND=72


# =============== FILTER SETTINGS ===============
MIN_24H_VOLUME=250000
MAX_SPREAD_PCT=0.004     # 0.4%

# liquidity must be good → code already checks (>0.55)


# =============== COOLDOWNS (seconds) ===============
COOLDOWN_QUICK_S=1800     # 30 min
COOLDOWN_MID_S=1800       # 30 min
COOLDOWN_TREND_S=3600     # 60 min

COOLDOWN_PERSIST_PATH=cooldown.json


# =============== LOGGING ===============
HELPERS_LOG_LEVEL=INFO